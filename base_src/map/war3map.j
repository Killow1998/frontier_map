    call SaveLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xEAFE0942, GetUnitLoc(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xF6952DAF)))
