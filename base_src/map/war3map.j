        call SetUnitState(GetTriggerUnit(), UNIT_STATE_MAX_LIFE, ( GetUnitState(GetTriggerUnit(), UNIT_STATE_MAX_LIFE) + 210.00 ))
        call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF06C56A2, ( ( GetHeroStr(GetTriggerUnit(), false) ) + ( GetHeroAgi(GetTriggerUnit(), false) ) + ( GetHeroInt(GetTriggerUnit(), false) ) ))
        call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xBE3351CB, ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF06C56A2) / 6 ))
