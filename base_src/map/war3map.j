    return ( ( GetItemTypeId(GetManipulatedItem()) == 'I03F' ) and ( ( IsUnitOwnedByPlayer(GetTriggerUnit(), Player(0)) == true ) or ( IsUnitOwnedByPlayer(GetTriggerUnit(), Player(1)) == true ) or ( IsUnitOwnedByPlayer(GetTriggerUnit(), Player(2)) == true ) or ( IsUnitOwnedByPlayer(GetTriggerUnit(), Player(3)) == true ) ) )
