endfunction
function Trig_sweet_soupActions takes nothing returns nothing
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    if ( ( GetUnitTypeId(GetTriggerUnit()) == 'E002' ) ) then
        if ( ( GetUnitAbilityLevel(GetTriggerUnit(), 'A06F') > 0 ) ) then
            call SetUnitState(GetTriggerUnit(), ConvertUnitState(0x16), ( GetUnitState(GetTriggerUnit(), ConvertUnitState(0x16)) - LoadReal(YDHT, 'E002', 0xF8535EA1) ))
            call SetUnitState(GetTriggerUnit(), ConvertUnitState(0x13), ( GetUnitState(GetTriggerUnit(), ConvertUnitState(0x13)) - LoadReal(YDHT, 'E002', 0x7340FB38) ))
        else
        endif
        if ( ( GetUnitAbilityLevel(GetTriggerUnit(), 'A06E') > 0 ) ) then
            call SetUnitState(GetTriggerUnit(), ConvertUnitState(0x51), ( GetUnitState(GetTriggerUnit(), ConvertUnitState(0x51)) - LoadReal(YDHT, 'E002', 0x0A2C3FB5) ))
            call SetUnitMoveSpeed(GetTriggerUnit(), ( GetUnitDefaultMoveSpeed(GetTriggerUnit()) - 0.00 ))
        else
        endif
        call DestroyEffect(LoadEffectHandle(YDHT, 'E002', 0x41B94617))
        call UnitRemoveAbility(GetTriggerUnit(), 'A06E')
        call UnitRemoveAbility(GetTriggerUnit(), 'A06F')
    else
    endif
    if ( ( GetUnitTypeId(GetTriggerUnit()) == 'H007' ) and ( GetUnitAbilityLevel(GetTriggerUnit(), 'A05T') > 0 ) and ( GetUnitAbilityLevel(GetTriggerUnit(), 'A05S') > 0 ) ) then
        call UnitRemoveAbility(GetTriggerUnit(), 'A05T')
        call UnitRemoveAbility(GetTriggerUnit(), 'A05S')
        call UnitModifySkillPoints(GetTriggerUnit(), LoadInteger(YDHT, 'H007', 0xFAFE5485))
        call UnitModifySkillPoints(GetTriggerUnit(), LoadInteger(YDHT, 'H007', 0x457BCFC0))
        call SaveInteger(YDHT, 'H007', 0xFAFE5485, 0)
        call SaveInteger(YDHT, 'H007', 0x457BCFC0, 0)
    else
    endif
    if ( ( GetUnitTypeId(GetTriggerUnit()) == 'H00A' ) and ( GetUnitAbilityLevel(GetTriggerUnit(), 'A067') > 0 ) ) then
        if ( ( LoadBoolean(YDHT, 'A067', 0x1010ED95) == true ) ) then
            call CreateNUnitsAtLoc(1, 'ewsp', GetOwningPlayer(GetTriggerUnit()), PolarProjectionBJ(GetUnitLoc(GetTriggerUnit()), 100.00, GetRandomDirectionDeg()), bj_UNIT_FACING)
            call SaveUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90BB9840, bj_lastCreatedUnit)
            call SetUnitInvulnerable(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90BB9840), true)
            call EXSetUnitCollisionType(false, LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90BB9840), 1)
            call ShowUnit(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90BB9840), false)
            call UnitAddAbility(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90BB9840), 'A068')
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6FA8F86, YDWEGetUnitAbilityDataReal(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90BB9840) , 'A068' , ( ( GetUnitAbilityLevel(GetTriggerUnit(), 'A067') ) - ( 1 ) ) , 106))
            call YDWETimerRemoveUnit(1.00 , LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90BB9840))
            call DestroyEffect(LoadEffectHandle(YDHT, 'A067', 0xFD1D8589))
            call SaveBoolean(YDHT, 'A067', 0x1010ED95, false)
            call SetUnitState(GetTriggerUnit(), ConvertUnitState(0x51), ( GetUnitState(GetTriggerUnit(), ConvertUnitState(0x51)) - LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6FA8F86) ))
        else
        endif
    else
    endif
    if ( ( GetUnitTypeId(GetTriggerUnit()) == 'H009' ) and ( GetUnitAbilityLevel(GetTriggerUnit(), 'A062') > 0 ) ) then
        call DestroyEffect(LoadEffectHandle(YDHT, 'H009', 0xF8F856EA))
    else
    endif
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
endfunction
