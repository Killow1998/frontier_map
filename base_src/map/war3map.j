    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x33E193A8, ( ( ( 300.00 + ( ( I2R(GetHeroStr(GetTriggerUnit(), true)) ) * ( 5.00 ) ) ) ) + ( I2R(GetUnitAbilityLevel(GetTriggerUnit(), 'A04O')) ) * ( 100.00 ) ))
