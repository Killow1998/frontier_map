    call AddSpecialEffectLocBJ(GetRectCenter(gg_rct_swimmingpool), "Abilities\\Spells\\Orc\\Reincarnation\\ReincarnationTarget.mdl")
    call YDWETimerDestroyEffect(3.00 , bj_lastCreatedEffect)
    set ydl_timer=CreateTimer()
    call TimerStart(ydl_timer, 3.00, false, function Trig_Emerald_useFunc005Func003T)
    set ydl_timer=null
endfunction
function Trig_Emerald_useActions takes nothing returns nothing
