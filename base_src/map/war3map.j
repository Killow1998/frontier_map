// Trigger: killtoget
//===========================================================================
function Trig_killtogetConditions takes nothing returns boolean
    return ( ( ( IsUnitOwnedByPlayer(GetTriggerUnit(), Player(PLAYER_NEUTRAL_AGGRESSIVE)) == true ) or ( IsUnitOwnedByPlayer(GetTriggerUnit(), Player(7)) == true ) or ( IsUnitOwnedByPlayer(GetTriggerUnit(), Player(8)) == true ) or ( IsUnitOwnedByPlayer(GetTriggerUnit(), Player(9)) == true ) or ( IsUnitOwnedByPlayer(GetTriggerUnit(), Player(10)) == true ) or ( IsUnitOwnedByPlayer(GetTriggerUnit(), Player(11)) == true ) ) and ( ( IsUnitOwnedByPlayer(GetKillingUnitBJ(), Player(0)) == true ) or ( IsUnitOwnedByPlayer(GetKillingUnitBJ(), Player(1)) == true ) or ( IsUnitOwnedByPlayer(GetKillingUnitBJ(), Player(2)) == true ) or ( IsUnitOwnedByPlayer(GetKillingUnitBJ(), Player(3)) == true ) ) )
endfunction
function Trig_killtogetActions takes nothing returns nothing
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6510CB32, GetUnitLevel(GetTriggerUnit()))
    call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6F96F2D2, GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ())))
    if ( ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6F96F2D2) <= 4 ) and ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6F96F2D2) >= 0 ) and ( ( IsUnitOwnedByPlayer(GetTriggerUnit(), Player(PLAYER_NEUTRAL_AGGRESSIVE)) == true ) or ( IsUnitOwnedByPlayer(GetTriggerUnit(), Player(10)) == true ) ) ) then
        call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6510CB32, R2I(( I2R(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6510CB32)) * 0.45 )))
        if ( ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6510CB32) == 0 ) ) then
            call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6510CB32, 1)
        else
            call DoNothing()
        endif
        set udg_credits[LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6F96F2D2)]=( udg_credits[LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6F96F2D2)] + LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6510CB32) )
    else
        set udg_credits[LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6F96F2D2)]=( udg_credits[LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6F96F2D2)] + LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6510CB32) )
    endif
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
endfunction
