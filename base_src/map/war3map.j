    call SetHeroInt(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x944CCEB0), ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA8780F52) * udg_boss_property ), true)
    call YDWESetUnitAbilityDataReal(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x944CCEB0) , 'A076' , 1 , 108 , ( 111.00 * I2R(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA8780F52)) ))
    call YDWESetUnitAbilityDataReal(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x944CCEB0) , 'A076' , 1 , 109 , ( 111.00 * I2R(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA8780F52)) ))
    call SetUnitAbilityLevel(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x944CCEB0), 'A076', 1)
    call YDWEAddAIOrder(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x944CCEB0) , 1 , 1 , "cripple" , null , null , 60)
    call YDWEAddAIOrder(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x944CCEB0) , 1 , 1 , "frostnova" , null , null , 60)
    call YDWEAddAIOrder(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x944CCEB0) , 1 , 3 , null , null , "howlofterror" , 45)
    call SetUnitManaPercentBJ(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x944CCEB0), 5.00)
    
    set ydl_timer=CreateTimer()
    call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0x944CCEB0, LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x944CCEB0))
    call TimerStart(ydl_timer, 5.00, true, function Trig_Soul_CollectorFunc022T)
