// Trigger: Group_healing_SCP
//===========================================================================
function Trig_Group_healing_SCPConditions takes nothing returns boolean
    return ( ( ( GetSpellAbilityId() == 'A08L' ) and ( GetUnitTypeId(GetTriggerUnit()) == 'u00J' ) ) )
endfunction
function Trig_Group_healing_SCPActions takes nothing returns nothing
    call DisplayTextToPlayer(GetOwningPlayer(GetTriggerUnit()), 0, 0, "Õø×ÕżŹµĢłµ×£Ķ¦”ÕÅæ")
    call YDWESetUnitAbilityDataReal(GetTriggerUnit() , 'A08L' , 1 , 108 , ( GetUnitState(GetTriggerUnit(), UNIT_STATE_LIFE) * 0.12 ))
    call YDWESetUnitAbilityDataReal(GetTriggerUnit() , 'A08N' , 1 , 108 , ( GetUnitState(GetTriggerUnit(), UNIT_STATE_LIFE) * 0.03 ))
    call IncUnitAbilityLevel(GetTriggerUnit(), 'A08L')
    call IncUnitAbilityLevel(GetTriggerUnit(), 'A08N')
    call DecUnitAbilityLevel(GetTriggerUnit(), 'A08L')
    call DecUnitAbilityLevel(GetTriggerUnit(), 'A08N')
    call IssueImmediateOrder(GetTriggerUnit(), "unimmolation")
    call IssueImmediateOrder(GetTriggerUnit(), "immolation")
    call SetUnitLifeBJ(GetTriggerUnit(), ( GetUnitState(GetTriggerUnit(), UNIT_STATE_LIFE) * 0.95 ))
endfunction
//===========================================================================
function InitTrig_Group_healing_SCP takes nothing returns nothing
    set gg_trg_Group_healing_SCP=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Group_healing_SCP, EVENT_PLAYER_UNIT_SPELL_CAST)
    call TriggerAddCondition(gg_trg_Group_healing_SCP, Condition(function Trig_Group_healing_SCPConditions))
    call TriggerAddAction(gg_trg_Group_healing_SCP, function Trig_Group_healing_SCPActions)
endfunction
