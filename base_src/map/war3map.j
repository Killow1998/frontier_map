// Trigger: artificial_sun
//===========================================================================
//TESH.scrollpos=0
//TESH.alwaysfold=0
function Trig_artificial_sun_Func_Timer takes nothing returns nothing
    // ŃĆÉõ┐«ÕżŹŃĆæ’╝ÜÕ┐ģķĪ╗ÕŖĀõĖŖ YDWE Õ▒Ćķā©ÕÅśķćÅÕłØÕ¦ŗÕī¢’╝īÕÉ”ÕłÖÕ«Åń╝¢Ķ»æõ╝ÜµŖźķöÖ’╝ü
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    
    // 1. Õģ│ķŚŁķüōÕģĘÕģ©Õ▒ĆÕ╝ĆÕģ│
    set udg_force_day=false
    
    // 2. µüóÕżŹÕż£µÖÜńÜäõĖ╗ÕĆÆĶ«ĪµŚČÕÆīķÜÉĶŚÅńÜäń╗łń╗ōĶ«ĪµŚČÕÖ©
    call ResumeTimer(udg_Night_Timer)
    call ResumeTimer(udg_Night_Timer_End)
    
    // 3. ŃĆÉĶ¦åĶ¦ēµüóÕżŹŃĆæ’╝ÜµŖŖµŚČķŚ┤ķćŹµ¢░ÕłćÕø×ķ╗æÕż£’╝łĶ«ŠõĖ║0.01ķü┐Õ╝Ć0.00ńÜäĶ¦”ÕÅæõ║ŗõ╗Č’╝ē
    call SetTimeOfDay(0.01)
    
    // 4. ŃĆÉµĀĖÕ┐āõ┐«ÕżŹŃĆæ’╝ÜķćŹµ¢░µśŠńż║ÕøŠĶģŠ’╝īÕ╣ČķćŹµ¢░ĶĄŗõ║łÕ«āńÜäõĖēõĖ¬ÕÄ¤ńö¤ÕģēńÄ»µŖĆĶāĮ’╝ü
    call ShowUnit(udg_Night_Totem, true)
    
    call UnitAddAbility(udg_Night_Totem, 'A0A7')
    call SetUnitAbilityLevel(udg_Night_Totem, 'A0A7', udg_difficulty)
    
    call UnitAddAbility(udg_Night_Totem, 'A0A8')
    call SetUnitAbilityLevel(udg_Night_Totem, 'A0A8', udg_difficulty)
    
    call UnitAddAbility(udg_Night_Totem, 'A0AE')
    call SetUnitAbilityLevel(udg_Night_Totem, 'A0AE', udg_difficulty)
    
    call DisplayTextToPlayer(GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xA6468E1C)), 0, 0, "|cffFFD700õ║║ķĆĀÕż¬ķś│ńÜäÕģēĶŖÆµČłµĢŻõ║å’╝īÕż£Ķē▓ÕåŹµ¼ĪķÖŹõĖ┤...|r")
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
    call DestroyTimer(GetExpiredTimer())
endfunction
function Trig_artificial_sun_Actions takes nothing returns nothing
    local timer ydl_timer
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    
    // ķś▓Õæåµ£║ÕłČ’╝ÜÕ”éµ×£µś»ńÖĮÕż®’╝īµł¢ĶĆģõ║║ķĆĀÕż¬ķś│ÕĘ▓ń╗ÅÕ£©ńö¤µĢł’╝īńø┤µÄźµŗÆń╗ØÕ╣ČķĆĆĶ┐śķüōÕģĘ’╝ü
    if ( LoadBoolean(YDHT, StringHash("µŚČķŚ┤"), 0x767B29CC) == true or udg_force_day == true ) then
        call DisplayTextToPlayer(GetOwningPlayer(GetTriggerUnit()), 0, 0, "|cffFF0000µŚĀµ│ĢõĮ┐ńö©’╝üńø«ÕēŹõĖŹµś»ķ╗æÕż£’╝īµł¢õ║║ķĆĀÕż¬ķś│ÕĘ▓Õ£©ńö¤µĢłõĖŁ’╝ü|r")
        call UnitAddItemByIdSwapped('I03V', GetTriggerUnit()) // ķĆĆĶ┐śķüōÕģĘ
call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
        return
    endif
    
    // 1. Õ╝ĆÕÉ»Õģ©Õ▒ĆÕ╝ĆÕģ│’╝īµēÆÕģēķóØÕż¢Ķ¦”ÕÅæńÜäķŁöµŖŚ
    set udg_force_day=true
    
    // 2. µÜéÕü£Õż£µÖÜńÜäõĖżõĖ¬µĀĖÕ┐āÕĆÆĶ«ĪµŚČ
    call PauseTimer(udg_Night_Timer)
    call PauseTimer(udg_Night_Timer_End)
    
    // 3. ŃĆÉĶ¦åĶ¦ēÕÅśõĖ║ńÖĮµś╝ŃĆæ
    call SetTimeOfDay(10.00)
    call UseTimeOfDayBJ(false)
    
    // 4. ŃĆÉµĀĖÕ┐āõ┐«ÕżŹŃĆæ’╝ÜÕ╝║ĶĪīķÜÉĶŚÅÕż£õ╣ŗÕøŠĶģŠ’╝īÕ╣ČÕĮ╗Õ║ĢÕłĀķÖżµēĆµ£ēÕÄ¤ńö¤ÕģēńÄ»’╝łÕŖĀķĆ¤ŃĆüµö╗Õć╗ÕŖøµÅÉÕŹć’╝ē’╝ü
    call ShowUnit(udg_Night_Totem, false)
    call UnitRemoveAbility(udg_Night_Totem, 'A0A7')
    call UnitRemoveAbility(udg_Night_Totem, 'A0A8')
    call UnitRemoveAbility(udg_Night_Totem, 'A0AE')
    
    call DisplayTextToPlayer(GetOwningPlayer(GetTriggerUnit()), 0, 0, "|cffFFD700õĮ┐ńö©õ║åŃĆÉõ║║ķĆĀÕż¬ķś│ŃĆæ’╝ü|r")
    
    // 5. Õ╝ĆÕÉ»ķüōÕģĘµīüń╗ŁµŚČķŚ┤Ķ«ĪµŚČÕÖ©
    set ydl_timer=CreateTimer()
    call SaveUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6468E1C, GetTriggerUnit())
    call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0xA6468E1C, LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6468E1C))
    
    // ķüōÕģĘµīüń╗ŁµŚČķŚ┤Ķ«ŠõĖ║ 120 ń¦Æ
    call TimerStart(ydl_timer, 120.00, false, function Trig_artificial_sun_Func_Timer)
    
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
    set ydl_timer=null
endfunction
