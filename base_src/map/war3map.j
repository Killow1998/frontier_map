//===========================================================================
// Trigger: poisonous_fog
//===========================================================================
function Trig_poisonous_fogConditions takes nothing returns boolean
    return ( ( ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true ) and ( GetUnitTypeId(GetTriggerUnit()) == 'N00Q' ) and ( GetSpellAbilityId() == 'A06W' ) ) )
endfunction
function Trig_poisonous_fogFunc016Func003A takes nothing returns nothing
    if ( ( ( IsUnitAliveBJ(GetEnumUnit()) == true ) and ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xE6E64075))) == true ) and ( IsUnitType(GetEnumUnit(), UNIT_TYPE_STRUCTURE) == false ) ) ) then
        call UnitDamageTarget(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xE6E64075), GetEnumUnit(), LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x33E193A8), false, false, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_WHOKNOWS)
        call AddSpecialEffectTargetUnitBJ("chest", GetEnumUnit(), "Abilities\\Spells\\Undead\\DeathandDecay\\DeathandDecayDamage.mdl")
        call YDWETimerDestroyEffect(0.35 , bj_lastCreatedEffect)
    else
    endif
endfunction
function Trig_poisonous_fogFunc016T takes nothing returns nothing
    local group ydl_group
    local unit ydl_unit
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xC29B70CD, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xC29B70CD) + 0.75 ))
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=12
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        call SaveLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x76D38C4E, PolarProjectionBJ(LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xEAFE0942), GetRandomReal(30.00, LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x90A2B744)), GetRandomDirectionDeg()))
        call AddSpecialEffectLocBJ(LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x76D38C4E), "Abilities\\Spells\\Undead\\DeathandDecay\\DeathandDecayTarget.mdl")
        call YDWETimerDestroyEffect(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xCF7F00A7) , bj_lastCreatedEffect)
        call RemoveLocation(LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x76D38C4E))
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call ForGroupBJ((YDWEGetUnitsInRangeOfLocMatchingNull(((LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x90A2B744) )*1.0) , ( LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xEAFE0942)) , null)), function Trig_poisonous_fogFunc016Func003A) // INLINED!!
    if ( ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xC29B70CD) > LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xCF7F00A7) ) ) then
        call RemoveLocation(LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xEAFE0942))
        call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
        call DestroyTimer(GetExpiredTimer())
    else
    endif
    set ydl_group=null
    set ydl_unit=null
endfunction
function Trig_poisonous_fogActions takes nothing returns nothing
    local timer ydl_timer
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
