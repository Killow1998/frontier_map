function Trig_emerald_getConditions takes nothing returns boolean
    return ( ( GetItemTypeId(GetManipulatedItem()) == 'I03B' ) )
endfunction
function Trig_emerald_getActions takes nothing returns nothing
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SaveUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB6A6EBAA, GetTriggerUnit())
    call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6295BDC, 'I03B')
    call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFAAE5B30, 'I03Z')
    call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x92070F1C, 0)
    call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x73EE4622, 3)
    set udg_task_int=0
    loop
        exitwhen udg_task_int > 5
        if ( ( GetItemTypeId(UnitItemInSlot(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB6A6EBAA), udg_task_int)) == LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6295BDC) ) ) then
            call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x92070F1C, ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x92070F1C) + 1 ))
        else
        endif
        set udg_task_int=udg_task_int + 1
    endloop
    if ( ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x92070F1C) >= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x73EE4622) ) ) then
        // --------------------
        // ÕÉłµłÉĶ»┤µśÄ
        call DisplayTextToPlayer(GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB6A6EBAA)), 0, 0, "µé©ńÜäķøćõĮŻÕģĄÕ░åõĖēÕØŚńóÄńēćõĖżõĖżÕ»╣Õćåń╝║ÕÅŻ’╝īĶ×ŹÕÉłµłÉõĖĆÕØŚÕ«īµĢ┤ńÜäń╗┐Õ«Øń¤│")
        // --------------------
        set udg_task_int=0
        loop
            exitwhen udg_task_int > 5
            if ( ( GetItemTypeId(UnitItemInSlot(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB6A6EBAA), udg_task_int)) == LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6295BDC) ) ) then
                call RemoveItem(UnitItemInSlot(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB6A6EBAA), udg_task_int))
                call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x92070F1C, ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x92070F1C) - 1 ))
                if ( ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x92070F1C) == 0 ) ) then
                    call DoNothing()
 exitwhen true //()
                else
                endif
            else
            endif
            set udg_task_int=udg_task_int + 1
        endloop
        call UnitAddItemByIdSwapped('I03Z', LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB6A6EBAA))
    else
    endif
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
endfunction
