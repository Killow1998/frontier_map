    local group ydl_group
    local unit ydl_unit
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x7789C18E, ( GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x08F74B43), UNIT_STATE_LIFE) * 0.11 ))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x71101AF5, ( GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x08F74B43), UNIT_STATE_MAX_LIFE) * ( 199.00 / 1000.00 ) ))
    if ( ( GetItemTypeId(YDWEGetItemOfTypeFromUnitBJNull(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x08F74B43) , 'I030')) == 'I030' ) ) then
        call UnitDamageTarget(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x08F74B43), LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x08F74B43), LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x7789C18E), false, false, ATTACK_TYPE_HERO, DAMAGE_TYPE_DIVINE, WEAPON_TYPE_WHOKNOWS)
        set udg_sunnum=1
        loop
            exitwhen udg_sunnum > GetRandomInt(4, 9)
            call SaveLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xEAFE0942, PolarProjectionBJ(GetUnitLoc(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x08F74B43)), GetRandomReal(100.00, 500.00), GetRandomDirectionDeg()))
            call AddSpecialEffectLocBJ(LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xEAFE0942), "Abilities\\Spells\\NightElf\\TrueshotAura\\TrueshotAura.mdl")
            call YDWETimerDestroyEffect(0.20 , bj_lastCreatedEffect)
