//===========================================================================
// Trigger: enemystart
//===========================================================================
//TESH.scrollpos=0
//TESH.alwaysfold=0
function Trig_enemystartFunc008Func002Func001A takes nothing returns nothing
    local location targetPt= GetRectCenter(gg_rct_base_area)
    
    if ( GetUnitCurrentOrder(GetEnumUnit()) == 0 ) then
        call IssuePointOrderLoc(GetEnumUnit(), "attack", targetPt)
    endif
    
    call RemoveLocation(targetPt)
    if ( ( IsUnitDeadBJ(GetEnumUnit()) == true ) ) then
        call GroupRemoveUnitSimple(GetEnumUnit(), LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xB569CC4E))
    endif
endfunction
function Trig_enemystartFunc008Func002T takes nothing returns nothing
    call ForGroupBJ(LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xB569CC4E), function Trig_enemystartFunc008Func002Func001A)
    call SaveInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x1D95A5A0, CountUnitsInGroup(LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xB569CC4E)))
    
    if ( ( LoadInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x1D95A5A0) == 0 ) or ( LoadInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x1D95A5A0) <= ( LoadInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x7696C3FB) / 5 ) ) ) then
        if ( ( udg_enemywaveCount == 4 ) and ( udg_bosscnt < 2 ) and ( udg_bosswave == false ) ) then
            set udg_bosswave=true
            call YDWETimerRunTrigger(2 , gg_trg_firstboss)
        elseif ( ( udg_enemywaveCount == 8 ) and ( udg_bosscnt < 3 ) and ( udg_bosswave == false ) ) then
            set udg_bosswave=true
            call YDWETimerRunTrigger(2 , gg_trg_secondboss)
        elseif ( ( udg_enemywaveCount == 12 ) and ( udg_bosscnt < 4 ) and ( udg_bosswave == false ) ) then
            set udg_bosswave=true
            call YDWETimerRunTrigger(2 , gg_trg_thirdboss)
        elseif ( ( udg_enemywaveCount == 16 ) and ( udg_bosscnt < 5 ) and ( udg_bosswave == false ) ) then
            set udg_bosswave=true
            call YDWETimerRunTrigger(2 , gg_trg_fourthboss)
        elseif ( ( udg_bosswave == false ) ) then
            set udg_enemywaveCount=( udg_enemywaveCount + 1 )
            call YDWETimerRunTrigger(2 , gg_trg_enemycoming)
            call YDWETimerRunTrigger(1.00 , gg_trg_tech_upgrade)
        endif
        call DestroyGroup(LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xB569CC4E))
        call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
        call DestroyTimer(GetExpiredTimer())
    endif
endfunction
function Trig_enemystartActions takes nothing returns nothing
    local timer ydl_timer
    local location spawnPt
    local real hpRatio= 1.00
    local real diffMult= 1.00
    local real playerMult= 1.00
    local real finalMult= 1.00
    
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SaveGroupHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB569CC4E, CreateGroup())
    call DestroyTimerDialog(udg_enemyTW)
    
    if ( udg_enemywaveCount <= 18 ) then
        
        // 1. ķÜŠÕ║”ÕĆŹńÄć
        if ( udg_difficulty <= 1 ) then
            set diffMult=1.00
            set hpRatio=1.00
        elseif ( udg_difficulty == 2 ) then
            set diffMult=1.50
            set hpRatio=1.35
        else
            set diffMult=2.00
            set hpRatio=1.80
        endif
        
        // 2. õ║║µĢ░ÕĆŹńÄć: 0.7 + 0.3 * players
        set playerMult=0.70 + ( I2R(CountPlayersInForceBJ(udg_player)) * 0.30 )
        
        // 3. Ķ«Īń«Śµ£Ćń╗łµĄ«ńé╣ń│╗µĢ░
        set finalMult=diffMult * playerMult
        
        // -------------------- µĢīÕåøńö¤µłÉÕŠ¬ńÄ» START --------------------
        
        // Õ¤║ńĪĆ 3õĖ¬
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=R2I(( 3.00 * finalMult ) + 0.999)
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            set spawnPt=GetRandomLocInRect(gg_rct_footman)
            call CreateNUnitsAtLoc(1, 'u00F', Player(7), spawnPt, bj_UNIT_FACING)
            call RemoveGuardPosition(bj_lastCreatedUnit)
            call SetUnitState(bj_lastCreatedUnit, UNIT_STATE_MAX_LIFE, GetUnitState(bj_lastCreatedUnit, UNIT_STATE_MAX_LIFE) * hpRatio)
            call SetUnitLifePercentBJ(bj_lastCreatedUnit, 100)
            call GroupAddUnit(LoadGroupHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB569CC4E), bj_lastCreatedUnit)
            call RemoveLocation(spawnPt)
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
        
        // Õ¤║ńĪĆ 2õĖ¬
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=R2I(( 2.00 * finalMult ) + 0.999)
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            set spawnPt=GetRandomLocInRect(gg_rct_boss_birth)
            call CreateNUnitsAtLoc(1, 'n011', Player(8), spawnPt, bj_UNIT_FACING)
            call RemoveGuardPosition(bj_lastCreatedUnit)
            call SetUnitState(bj_lastCreatedUnit, UNIT_STATE_MAX_LIFE, ( GetUnitState(bj_lastCreatedUnit, UNIT_STATE_MAX_LIFE) + ( 62.00 * I2R(udg_enemywaveCount) ) ) * hpRatio)
            call SetUnitLifePercentBJ(bj_lastCreatedUnit, 100)
            call GroupAddUnit(LoadGroupHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB569CC4E), bj_lastCreatedUnit)
            call RemoveLocation(spawnPt)
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
        
        // Õ¤║ńĪĆ 2õĖ¬
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=R2I(( 2.00 * finalMult ) + 0.999)
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            set spawnPt=GetRandomLocInRect(gg_rct_rideman)
            call CreateNUnitsAtLoc(1, 'o002', Player(9), spawnPt, bj_UNIT_FACING)
            call RemoveGuardPosition(bj_lastCreatedUnit)
            call SetUnitState(bj_lastCreatedUnit, UNIT_STATE_MAX_LIFE, GetUnitState(bj_lastCreatedUnit, UNIT_STATE_MAX_LIFE) * hpRatio)
            call SetUnitLifePercentBJ(bj_lastCreatedUnit, 100)
            call GroupAddUnit(LoadGroupHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB569CC4E), bj_lastCreatedUnit)
            call RemoveLocation(spawnPt)
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
        
        if ( ( udg_enemywaveCount >= 7 ) ) then
            // Õ¤║ńĪĆ 3õĖ¬
            set bj_forLoopAIndex=1
            set bj_forLoopAIndexEnd=R2I(( 3.00 * finalMult ) + 0.999)
            loop
                exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
                set spawnPt=GetRandomLocInRect(gg_rct_boss_birth)
                call CreateNUnitsAtLoc(1, 'u00I', Player(9), spawnPt, bj_UNIT_FACING)
                call RemoveGuardPosition(bj_lastCreatedUnit)
                call SetUnitState(bj_lastCreatedUnit, UNIT_STATE_MAX_LIFE, GetUnitState(bj_lastCreatedUnit, UNIT_STATE_MAX_LIFE) * hpRatio)
                call SetUnitLifePercentBJ(bj_lastCreatedUnit, 100)
                call GroupAddUnit(LoadGroupHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB569CC4E), bj_lastCreatedUnit)
                call RemoveLocation(spawnPt)
                set bj_forLoopAIndex=bj_forLoopAIndex + 1
            endloop
        endif
        
        if ( ( udg_enemywaveCount >= 11 ) ) then
            // Õ¤║ńĪĆ 2õĖ¬
            set bj_forLoopAIndex=1
            set bj_forLoopAIndexEnd=R2I(( 2.00 * finalMult ) + 0.999)
            loop
                exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
                set spawnPt=GetRandomLocInRect(gg_rct_boss_birth)
                call CreateNUnitsAtLoc(1, 'u00J', Player(7), spawnPt, bj_UNIT_FACING)
                call RemoveGuardPosition(bj_lastCreatedUnit)
                call SetUnitState(bj_lastCreatedUnit, UNIT_STATE_MAX_LIFE, GetUnitState(bj_lastCreatedUnit, UNIT_STATE_MAX_LIFE) * hpRatio)
                call SetUnitLifePercentBJ(bj_lastCreatedUnit, 100)
                call GroupAddUnit(LoadGroupHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB569CC4E), bj_lastCreatedUnit)
                call RemoveLocation(spawnPt)
                set bj_forLoopAIndex=bj_forLoopAIndex + 1
            endloop
        endif
        
        if ( ( udg_enemywaveCount >= 14 ) ) then
            // Õ¤║ńĪĆ 2õĖ¬
            set bj_forLoopAIndex=1
            set bj_forLoopAIndexEnd=R2I(( 2.00 * finalMult ) + 0.999)
            loop
                exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
                set spawnPt=GetRandomLocInRect(gg_rct_boss_birth)
                call CreateNUnitsAtLoc(1, 'o003', Player(8), spawnPt, bj_UNIT_FACING)
                call RemoveGuardPosition(bj_lastCreatedUnit)
                call SetUnitState(bj_lastCreatedUnit, UNIT_STATE_MAX_LIFE, GetUnitState(bj_lastCreatedUnit, UNIT_STATE_MAX_LIFE) * hpRatio)
                call SetUnitLifePercentBJ(bj_lastCreatedUnit, 100)
                call GroupAddUnit(LoadGroupHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB569CC4E), bj_lastCreatedUnit)
                call RemoveLocation(spawnPt)
                set bj_forLoopAIndex=bj_forLoopAIndex + 1
            endloop
        endif
        // -------------------- µĢīÕåøńö¤µłÉÕŠ¬ńÄ» END --------------------
        call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x7696C3FB, CountUnitsInGroup(LoadGroupHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB569CC4E)))
        call DisplayTextToForce(GetPlayersAll(), "ń¼¼" + I2S(udg_enemywaveCount) + "µ│óµĢīÕåøÕĘ▓Õ▒ĢÕ╝Ćµö╗ÕŖ┐")
        call YDWEPolledWaitNull(1.00)
        call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
        
        set ydl_timer=CreateTimer()
        call SaveInteger(YDLOC, GetHandleId(ydl_timer), 0x7696C3FB, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x7696C3FB))
        call SaveGroupHandle(YDLOC, GetHandleId(ydl_timer), 0xB569CC4E, LoadGroupHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB569CC4E))
        call TimerStart(ydl_timer, 1.00, true, function Trig_enemystartFunc008Func002T)
    else
        // µ│óµ¼Ī > 18’╝īńø┤µÄźĶ┐øÕå│µłśķĆ╗ĶŠæ
        // call ConditionalTriggerExecute(gg_trg_finalround)
        call ConditionalTriggerExecute(gg_trg_final_round_remake)
        
    endif
    
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
    set ydl_timer=null
endfunction
function InitTrig_enemystart takes nothing returns nothing
    set gg_trg_enemystart=CreateTrigger()
    call TriggerRegisterTimerExpireEvent(gg_trg_enemystart, udg_enemyT)
    call TriggerAddAction(gg_trg_enemystart, function Trig_enemystartActions)
endfunction//===========================================================================
// Trigger: final_round_remake
//===========================================================================
function Trig_final_round_remakeFunc005Func001A takes nothing returns nothing
    if ( ( ( 0 == 0 ) or ( GetUnitCurrentOrder(GetEnumUnit()) == ( 0 ) ) ) ) then
        call SaveLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xFC4D8276, GetRectCenter(gg_rct_base_area))
        call IssuePointOrderLoc(GetEnumUnit(), "attack", LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xFC4D8276))
        call RemoveLocation(LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xFC4D8276))
    else
    endif
    if ( ( IsUnitDeadBJ(GetEnumUnit()) == true ) ) then
        call GroupRemoveUnit(LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xA465778C), GetEnumUnit())
    else
    endif
endfunction
function Trig_final_round_remakeFunc005Func002Func003T takes nothing returns nothing
    call ConditionalTriggerExecute(gg_trg_mission_success)
endfunction
function Trig_final_round_remakeFunc005T takes nothing returns nothing
    local group ydl_group
    local unit ydl_unit
    local timer ydl_timer
    call ForGroupBJ(LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xA465778C), function Trig_final_round_remakeFunc005Func001A)
    if ( ( IsUnitGroupEmptyBJ(LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xA465778C)) == true ) ) then
        call DisplayTextToPlayer(GetLocalPlayer(), 0, 0, "õĮĀõ╗¼Õć╗Ķ┤źõ║åµēĆµ£ēĶ┐øµö╗ńÜäµĢīÕåø’╝üõĮĀõ╗¼Õ«łõĮÅõ║åõ╝ĀķĆüķöÜńé╣’╝īÕĖØÕøĮÕ░åõ╗źµŁżµłśõĖ║ķöŗķöÉ’╝īÕł║ń®┐µĢīÕåøńÜäÕ┐āĶäÅ’╝ü’╝ü’╝ü")
        call DisplayTextToPlayer(GetLocalPlayer(), 0, 0, "µüŁÕ¢£õĮĀõ╗¼ķĆÜÕģ│’╝īµĖĖµłÅÕ░åÕ£©10ń¦ÆÕÉÄń╗ōµØ¤")
        set ydl_timer=CreateTimer()
        call TimerStart(ydl_timer, 10.00, false, function Trig_final_round_remakeFunc005Func002Func003T)
    else
    endif
    set ydl_group=null
    set ydl_unit=null
    set ydl_timer=null
endfunction
function Trig_final_round_remakeActions takes nothing returns nothing
    local timer ydl_timer
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call ConditionalTriggerExecute(gg_trg_reinforcements)
    call SaveGroupHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA465778C, CreateGroup())
    set udg_sheepnum=1
    loop
        exitwhen udg_sheepnum > 67
        call SaveLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xEAFE0942, GetRandomLocInRect(gg_rct_boss_birth))
        call CreateNUnitsAtLoc(1, 'n012', Player(11), LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xEAFE0942), bj_UNIT_FACING)
        call GroupAddUnit(LoadGroupHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA465778C), bj_lastCreatedUnit)
        call RemoveLocation(LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xEAFE0942))
        set udg_sheepnum=udg_sheepnum + 1
    endloop
    call DisplayTextToPlayer(GetLocalPlayer(), 0, 0, "µ£ĆÕÉÄõĖĆµ│óµĢīõ║║ÕĘ▓Ķ┐øµö╗’╝ü")
    set ydl_timer=CreateTimer()
    call SaveGroupHandle(YDLOC, GetHandleId(ydl_timer), 0xA465778C, LoadGroupHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA465778C))
    call SaveLocationHandle(YDLOC, GetHandleId(ydl_timer), 0xFC4D8276, LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFC4D8276))
    call TimerStart(ydl_timer, 3.00, true, function Trig_final_round_remakeFunc005T)
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
    set ydl_timer=null
endfunction
//===========================================================================
function InitTrig_final_round_remake takes nothing returns nothing
    set gg_trg_final_round_remake=CreateTrigger()
    call TriggerAddAction(gg_trg_final_round_remake, function Trig_final_round_remakeActions)
endfunction
