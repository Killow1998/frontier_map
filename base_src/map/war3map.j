    call DisplayTimedTextToPlayer(GetTriggerPlayer(), 0, 0, 30, "|cFF1E90FFÕĮōÕēŹń╝¢ĶŠæÕÖ©ńēłµ£¼õĖ║’╝Ü |r|cFF00FF00YDWE 1.32.12.181229")
