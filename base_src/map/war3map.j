    // ==================== ń╗¤õĖĆµŗ”µł¬õĖÄµēōµ¢Ł ====================
    if is_used == true then
        call IssueImmediateOrder(caster, "stop")
        call DisplayTextToPlayer(GetOwningPlayer(caster), 0, 0, "Ķ»źĶ║»õĮōÕĘ▓µ▒▓ÕÅ¢Ķ┐ćµŁżķśČń║¦ńÜäÕÄ¤ńĮ¬’╝īµŚĀµ│ĢķćŹÕżŹĶÄĘÕÅ¢’╝ü")
        // Õ”éµ×£Ķó½µŗ”µł¬’╝īÕ┐ģķĪ╗Õ£© return ÕēŹķćŖµöŠÕ▒Ćķā©ÕåģÕŁś’╝īķś▓µŁóÕåģÕŁśµ│äķ£▓
        call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
        return
