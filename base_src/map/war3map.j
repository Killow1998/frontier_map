function Trig_holy_light_guardianConditions takes nothing returns boolean
    return ( ( GetSpellAbilityId() == 'A0A3' ) )
endfunction
function Trig_holy_light_guardianFunc002Func004T takes nothing returns nothing
    call SetUnitInvulnerable(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xFC4D8276), false)
    call DestroyEffect(LoadEffectHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xF8F856EA))
endfunction
function Trig_holy_light_guardianFunc002Func007T takes nothing returns nothing
    call SetUnitInvulnerable(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xFC4D8276), false)
    call DestroyEffect(LoadEffectHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xF8F856EA))
endfunction
function Trig_holy_light_guardianActions takes nothing returns nothing
    local timer ydl_timer
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SaveUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFC4D8276, GetSpellTargetUnit())
    if ( ( IsUnitType(GetSpellTargetUnit(), UNIT_TYPE_STRUCTURE) == true ) ) then
        call SaveEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF8F856EA, AddSpecialEffectTarget("Abilities\\Spells\\Items\\AIda\\AIdaTarget.mdl", LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFC4D8276), "overhead"))
        call SetUnitInvulnerable(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFC4D8276), true)
        call SetUnitLifePercentBJ(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFC4D8276), ( GetUnitLifePercent(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFC4D8276)) + 9.10 ))
        set ydl_timer=CreateTimer()
        call SaveEffectHandle(YDLOC, GetHandleId(ydl_timer), 0xF8F856EA, LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF8F856EA))
        call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0xFC4D8276, LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFC4D8276))
        call TimerStart(ydl_timer, 21.00, false, function Trig_holy_light_guardianFunc002Func007T)
    else
        call SaveEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF8F856EA, AddSpecialEffectTarget("Abilities\\Spells\\Human\\DivineShield\\DivineShieldTarget.mdl", LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFC4D8276), "origin"))
        call SetUnitInvulnerable(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFC4D8276), true)
        set ydl_timer=CreateTimer()
        call SaveEffectHandle(YDLOC, GetHandleId(ydl_timer), 0xF8F856EA, LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF8F856EA))
        call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0xFC4D8276, LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFC4D8276))
        call TimerStart(ydl_timer, 4.70, false, function Trig_holy_light_guardianFunc002Func004T)
    endif
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
    set ydl_timer=null
endfunction
