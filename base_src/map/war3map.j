    call YDWETimerDestroyEffect(1.00 , AddSpecialEffectLoc("Abilities\\Spells\\NightElf\\Blink\\BlinkCaster.mdl", GetUnitLoc(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF6649597))))
    set ydl_timer=CreateTimer()
    call SaveInteger(YDLOC, GetHandleId(ydl_timer), 0x4C448388, 0)
    call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0xF6649597, LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF6649597))
    call SaveLocationHandle(YDLOC, GetHandleId(ydl_timer), 0x580AD404, LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x580AD404))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0x33E193A8, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x33E193A8))
    call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0x90BB9840, LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90BB9840))
    call SaveInteger(YDLOC, GetHandleId(ydl_timer), 0xD8242F63, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xD8242F63))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0x5536E8A1, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x5536E8A1))
    call SaveLocationHandle(YDLOC, GetHandleId(ydl_timer), 0xEAFE0942, LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xEAFE0942))
    call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0xFC4D8276, LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFC4D8276))
    call SaveGroupHandle(YDLOC, GetHandleId(ydl_timer), 0x3997298D, LoadGroupHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x3997298D))
    call SaveEffectHandle(YDLOC, GetHandleId(ydl_timer), 0xFE88D7FF, LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFE88D7FF))
    call TimerStart(ydl_timer, 0.45, true, function Trig_Tempest_of_TerminationFunc013T)
