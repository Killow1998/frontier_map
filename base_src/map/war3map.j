function Trig_hp_stealConditions takes nothing returns boolean
    return ( ( GetEventDamage() >= 1.00 ) )
endfunction
function Trig_hp_stealActions takes nothing returns nothing
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6EA533B2, 0.00)
    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x33E193A8, GetEventDamage())
    if ( ( UnitHasBuffBJ(GetEventDamageSource(), 'B009') == true ) and ( GetUnitState(GetEventDamageSource(), ConvertUnitState(0x16)) <= 250.00 ) ) then
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6EA533B2, ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6EA533B2) ) + ( 0.07 ) ))
    else
        if ( ( UnitHasBuffBJ(GetEventDamageSource(), 'B00T') == true ) and ( GetUnitState(GetEventDamageSource(), ConvertUnitState(0x16)) <= 250.00 ) ) then
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6EA533B2, ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6EA533B2) ) + ( 0.13 ) ))
        else
        endif
    endif
    if ( ( GetItemTypeId(YDWEGetItemOfTypeFromUnitBJNull(GetEventDamageSource() , 'I027')) == 'I027' ) ) then
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6EA533B2, ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6EA533B2) ) + ( 0.06 ) ))
    else
        if ( ( GetItemTypeId(YDWEGetItemOfTypeFromUnitBJNull(GetEventDamageSource() , 'I028')) == 'I028' ) ) then
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6EA533B2, ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6EA533B2) ) + ( 0.07 ) ))
        else
            if ( ( GetItemTypeId(YDWEGetItemOfTypeFromUnitBJNull(GetEventDamageSource() , 'I022')) == 'I022' ) ) then
                call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6EA533B2, ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6EA533B2) ) + ( 0.13 ) ))
            else
            endif
        endif
    endif
    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x65A4C841, ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6EA533B2) * LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x33E193A8) ))
    if ( ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x65A4C841) >= 10.00 ) and ( GetUnitState(GetEventDamageSource(), UNIT_STATE_MAX_LIFE) > GetUnitState(GetEventDamageSource(), UNIT_STATE_LIFE) ) ) ) then
        call AddSpecialEffectTargetUnitBJ("chest", GetEventDamageSource(), "Abilities\\Spells\\Undead\\VampiricAura\\VampiricAuraTarget.mdl")
        call SetUnitLifeBJ(GetEventDamageSource(), ( GetUnitState(GetEventDamageSource(), UNIT_STATE_LIFE) + LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x65A4C841) ))
        call YDWETimerDestroyEffect(0.20 , bj_lastCreatedEffect)
    else
    endif
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
endfunction
