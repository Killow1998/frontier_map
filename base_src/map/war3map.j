    if ( ( ( IsUnitDeadBJ(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)) == true ) or ( GetUnitManaPercent(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)) < LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x356950DB) ) or ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xC29B70CD) >= LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xCF7F00A7) ) ) ) then
