                call DisplayTextToPlayer(GetOwningPlayer(GetKillingUnitBJ()), 0, 0, ( "ńé╝ĶŹ»ÕĖłķĆÜĶ┐ćńö¤ÕæĮńé╝µłÉĶÄĘÕŠŚõ║åķóØÕż¢ÕŖøķćÅ’╝Ü" + I2S(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x4EF831CF)) ))
