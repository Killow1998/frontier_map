function Trig_tower_taskFunc007Func002Func010Conditions takes nothing returns nothing
    local group ydl_group
    local unit ydl_unit
    local timer ydl_timer
    if ( ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_STRUCTURE) == true ) and ( GetUnitTypeId(GetTriggerUnit()) == 'h00Q' ) ) then
        call SetUnitInvulnerable(GetTriggerUnit(), true)
        call UnitShareVision(GetTriggerUnit(), Player(0), true)
        call UnitShareVision(GetTriggerUnit(), Player(1), true)
        call UnitShareVision(GetTriggerUnit(), Player(2), true)
        call UnitShareVision(GetTriggerUnit(), Player(3), true)
        set udg_effect_int=1
        loop
            exitwhen udg_effect_int > 12
            call SaveLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xEAFE0942, GetUnitLoc(GetTriggerUnit()))
            call SaveLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xEAFE0942, PolarProjectionBJ(LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xEAFE0942), 128.00, ( ( 30.00 ) * ( I2R(udg_effect_int) ) )))
            call AddSpecialEffectLocBJ(LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xEAFE0942), "Abilities\\Spells\\Human\\Flare\\FlareCaster.mdl")
            call YDWETimerDestroyEffect(2 , bj_lastCreatedEffect)
            call RemoveLocation(LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xEAFE0942))
            set udg_effect_int=udg_effect_int + 1
        endloop
        call QuestSetCompleted(LoadQuestHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xFC49F013), true)
        call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_COMPLETED, "[ń®┐õ║æõ╣ŗõ┐Ī]ŌĆöŌĆöķŁöµ│Ģõ┐ĪÕÅĘÕĪöÕĘ▓Õ╗║µłÉ’╝īµłæõ╗¼ÕĘ▓ń╗ÅÕÉæÕÅŗÕåøĶ»Ęµ▒éµö»µÅ┤’╝īÕĖīµ£øõ╗¢õ╗¼ĶāĮÕ░ĮÕ┐½ķ®░µÅ┤’╝üńź×’╝īĶ»ĘńźØń”Åµłæõ╗¼")
        call ForGroupBJ(udg_hero_select, function Trig_tower_taskFunc007Func002Func010Func002Func009A)
        set udg_build_finish=true
        // --------------------
        // Õ╗║ńŁæÕĖłķĆāĶĘæ
        call SaveLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xEAFE0942, GetRectCenter(gg_rct_base_area))
        call SetUnitMoveSpeed(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB6A6EBAA), 522.00)
        call IssuePointOrderLoc(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB6A6EBAA), "move", LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xEAFE0942))
        call RemoveLocation(LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xEAFE0942))
        set ydl_timer=CreateTimer()
        call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0xB6A6EBAA, LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB6A6EBAA))
        call TimerStart(ydl_timer, 1.00, true, function Trig_tower_taskFunc007Func002Func010Func002Func011Func005T)
        // --------------------
        call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()))
        call DestroyTrigger(GetTriggeringTrigger())
    else
    endif
    set ydl_group=null
    set ydl_unit=null
    set ydl_timer=null
endfunction
function Trig_tower_taskFunc007Conditions takes nothing returns nothing
    local timer ydl_timer
    local trigger ydl_trigger
    if ( ( GetItemTypeId(GetManipulatedItem()) == 'I03Y' ) ) then
        call SaveLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xEAFE0942, PolarProjectionBJ(GetUnitLoc(GetTriggerUnit()), 50.00, GetRandomDirectionDeg()))
        call CreateNUnitsAtLoc(1, 'h00S', Player(4), LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xEAFE0942), bj_UNIT_FACING)
        call RemoveLocation(LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xEAFE0942))
        call SaveUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB6A6EBAA, bj_lastCreatedUnit)
        call SaveLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xEAFE0942, GetRectCenter(gg_rct_to_build_tower))
        call YDWEIssueBuildOrderByIdLocBJNull(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB6A6EBAA) , 'h00Q' , LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xEAFE0942))
        call RemoveLocation(LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xEAFE0942))
        call SaveTimerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x5B523ACE, CreateTimer())
        set ydl_timer=LoadTimerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x5B523ACE)
        call SaveGroupHandle(YDLOC, GetHandleId(ydl_timer), 0xECC38EC2, LoadGroupHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECC38EC2))
        call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0xE6E64075, LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xE6E64075))
        call SaveQuestHandle(YDLOC, GetHandleId(ydl_timer), 0xFC49F013, LoadQuestHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xFC49F013))
        call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0xB6A6EBAA, LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB6A6EBAA))
        call TimerStart(ydl_timer, 1.00, true, function Trig_tower_taskFunc007Func002Func009T)
        set ydl_trigger=CreateTrigger()
        call SaveUnitHandle(YDLOC, GetHandleId(ydl_trigger), 0xB6A6EBAA, LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB6A6EBAA))
        call SaveUnitHandle(YDLOC, GetHandleId(ydl_trigger), 0xE6E64075, LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xE6E64075))
        call SaveLocationHandle(YDLOC, GetHandleId(ydl_trigger), 0xEAFE0942, LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xEAFE0942))
        call SaveQuestHandle(YDLOC, GetHandleId(ydl_trigger), 0xFC49F013, LoadQuestHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xFC49F013))
        call TriggerRegisterAnyUnitEventBJ(ydl_trigger, EVENT_PLAYER_UNIT_CONSTRUCT_FINISH)
        call TriggerAddCondition(ydl_trigger, Condition(function Trig_tower_taskFunc007Func002Func010Conditions))
        call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()))
        call DestroyTrigger(GetTriggeringTrigger())
    else
    endif
    set ydl_timer=null
    set ydl_trigger=null
endfunction
function Trig_tower_taskActions takes nothing returns nothing
    local trigger ydl_trigger
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SaveQuestHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFC49F013, CreateQuestBJ(bj_QUESTTYPE_OPT_UNDISCOVERED, "ń®┐õ║æõ╣ŗõ┐Ī", "µ┤ŠÕć║ńÜäõ╝Āõ┐ĪÕģĄÕØćµŚĀµČłµü»’╝īµĢīÕåøÕĘ▓ń╗ÅµśÄÕ»¤ĶÉźÕ£░ĶÖÜÕ«×’╝īµłæõ╗¼Õ”éõĮĢµēŹĶāĮńĀ┤Õ▒Ć", "ReplaceableTextures\\CommandButtons\\BTNHumanWatchTower.blp"))
    call QuestSetEnabled(LoadQuestHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFC49F013), true)
    set ydl_trigger=CreateTrigger()
    call SaveQuestHandle(YDLOC, GetHandleId(ydl_trigger), 0xFC49F013, LoadQuestHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFC49F013))
    call TriggerRegisterUnitEvent(ydl_trigger, gg_unit_n01E_0019, EVENT_UNIT_DEATH)
    call TriggerAddCondition(ydl_trigger, Condition(function Trig_tower_taskFunc004Conditions))
    set ydl_trigger=CreateTrigger()
    call SaveQuestHandle(YDLOC, GetHandleId(ydl_trigger), 0xFC49F013, LoadQuestHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFC49F013))
    call TriggerRegisterAnyUnitEventBJ(ydl_trigger, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(ydl_trigger, Condition(function Trig_tower_taskFunc005Conditions))
    set ydl_trigger=CreateTrigger()
    call SaveLocationHandle(YDLOC, GetHandleId(ydl_trigger), 0xEAFE0942, LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xEAFE0942))
    call SaveQuestHandle(YDLOC, GetHandleId(ydl_trigger), 0xFC49F013, LoadQuestHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFC49F013))
    call YDWETriggerRegisterEnterRectSimpleNull(ydl_trigger , gg_rct_base_area)
    call TriggerAddCondition(ydl_trigger, Condition(function Trig_tower_taskFunc006Conditions))
    set ydl_trigger=CreateTrigger()
    call SaveGroupHandle(YDLOC, GetHandleId(ydl_trigger), 0xECC38EC2, LoadGroupHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xECC38EC2))
