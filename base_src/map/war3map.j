        call SaveLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xEAFE0942, PolarProjectionBJ(GetUnitLoc(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xFC4D8276)), GetRandomReal(49.00, 129.00), GetRandomDirectionDeg()))
        call SetUnitX(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xF6649597), GetLocationX(LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xEAFE0942)))
        call SetUnitY(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xF6649597), GetLocationY(LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xEAFE0942)))
        call YDWETimerDestroyEffect(0.20 , AddSpecialEffectTarget("Abilities\\Weapons\\Blood\\BloodImpact.mdl", LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xFC4D8276), "overhead"))
        if ( ( IsUnitEnemy(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xFC4D8276), GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xF6649597))) == true ) ) then
            call UnitDamageTarget(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xF6649597), LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xFC4D8276), ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x33E193A8) * ( 1.00 + LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x5536E8A1) ) ), true, false, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_DEMOLITION, WEAPON_TYPE_METAL_HEAVY_SLICE)
            if ( ( IsUnitDeadBJ(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xFC4D8276)) == true ) ) then
                call CreateNUnitsAtLoc(1, 'e004', GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xF6649597)), LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xEAFE0942), bj_UNIT_FACING)
                call SaveUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x90BB9840, bj_lastCreatedUnit)
                call ShowUnit(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x90BB9840), false)
                call SetUnitInvulnerable(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x90BB9840), true)
                call SetUnitPathing(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x90BB9840), false)
                call UnitAddAbility(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x90BB9840), 'A0AC')
                call SetUnitAbilityLevel(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x90BB9840), 'A0AC', 1)
                call IssueImmediateOrder(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x90BB9840), "stomp")
                call YDWETimerRemoveUnit(2.00 , LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x90BB9840))
            else
            endif
        else
        endif
        call RemoveLocation(LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xEAFE0942))
        call SaveInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x4C448388, ( LoadInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x4C448388) + 1 ))
    else
