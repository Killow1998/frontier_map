    call SaveGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x310EC19E, YDWEGetUnitsInRangeOfLocMatchingNull(700.00 , GetUnitLoc(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x400B680E)) , Condition(function Trig_hpwaveFunc014Func012003003)))
