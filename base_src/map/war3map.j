    call DisplayTextToPlayer(GetOwningPlayer(GetTriggerUnit()), 0, 0, "õĖ╗ÕŖ©õĮ┐ńö©õĖōµŁ”ÕÅ»ĶÄĘÕÅ¢ÕÄ¤ńĮ¬ÕŖøķćÅ’╝īµ»Åµ¼ĪÕŹćń║¦õ╣ŗÕÉÄÕÅ»õĮ┐ńö©õĖĆµ¼Ī")
    call UnitAddItemByIdSwapped('I023', bj_lastCreatedUnit)
