function Trig_time_shieldConditions takes nothing returns boolean
    return ( ( GetItemTypeId(YDWEGetItemOfTypeFromUnitBJNull(GetTriggerUnit() , 'I02U')) == 'I02U' ) )
endfunction
function Trig_time_shieldActions takes nothing returns nothing
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    if ( ( GetRandomInt(1, 100) <= 30 ) ) then
        call CreateNUnitsAtLoc(1, 'ewsp', GetOwningPlayer(GetTriggerUnit()), GetUnitLoc(GetEventDamageSource()), bj_UNIT_FACING)
        call SaveUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90BB9840, bj_lastCreatedUnit)
        call ShowUnit(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90BB9840), false)
        call SetUnitInvulnerable(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90BB9840), true)
        call UnitAddAbility(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90BB9840), 'A09C')
        call IssueTargetOrder(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90BB9840), "slow", GetEventDamageSource())
        call YDWETimerRemoveUnit(3.00 , LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90BB9840))
        call YDWEGeneralBounsSystemUnitSetBonus(GetEventDamageSource() , 2 , 1 , 3)
        call YDWEPolledWaitNull(3.00)
        call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
        call YDWEGeneralBounsSystemUnitSetBonus(GetEventDamageSource() , 2 , 0 , 3)
    else
    endif
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
endfunction
