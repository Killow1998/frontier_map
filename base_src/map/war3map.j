function Trig_shield_throwConditions takes nothing returns boolean
    return ( ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true ) )
endfunction
function Trig_shield_throwActions takes nothing returns nothing
    if ( ( IsUnitInGroup(GetTriggerUnit(), udg_shield1) == true ) and ( GetItemTypeId(GetManipulatedItem()) == 'I00F' ) ) then
        call GroupRemoveUnit(udg_shield1, GetTriggerUnit())
        call UnitRemoveAbility(GetTriggerUnit(), 'A010')
    else
    endif
    if ( ( IsUnitInGroup(GetTriggerUnit(), udg_shield2) == true ) and ( GetItemTypeId(GetManipulatedItem()) == 'I00J' ) ) then
        call GroupRemoveUnit(udg_shield2, GetTriggerUnit())
        call UnitRemoveAbility(GetTriggerUnit(), 'A011')
    else
    endif
    if ( ( IsUnitInGroup(GetTriggerUnit(), udg_shield3) == true ) and ( GetItemTypeId(GetManipulatedItem()) == 'I00I' ) ) then
        call GroupRemoveUnit(udg_shield3, GetTriggerUnit())
        call UnitRemoveAbility(GetTriggerUnit(), 'A014')
    else
    endif
    if ( ( IsUnitInGroup(GetTriggerUnit(), udg_shield3) == true ) and ( GetItemTypeId(GetManipulatedItem()) == 'I00E' ) ) then
        call GroupRemoveUnit(udg_shield3, GetTriggerUnit())
        call UnitRemoveAbility(GetTriggerUnit(), 'A00Z')
    else
    endif
endfunction
