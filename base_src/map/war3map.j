    call CreateTimerDialogBJ(udg_enemyT, ( ( "ĶĘØń”╗ń¼¼" ) + ( I2S(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xDEE404E2)) ) + ( "µ¼ĪµĢīµ¢╣Ķ┐øÕåøĶ┐śµ£ē" ) ))
    set udg_enemyTW=bj_lastCreatedTimerDialog
    
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
