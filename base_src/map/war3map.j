")
        set ydl_timer=CreateTimer()
        call SaveQuestHandle(YDLOC, GetHandleId(ydl_timer), 0xFC49F013, LoadQuestHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xFC49F013))
        call TimerStart(ydl_timer, 1.00, false, function Trig_tower_taskFunc006Func001Func008Func001Func008T)
        call SaveLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xEAFE0942, GetUnitLoc(GetTriggerUnit()))
        set udg_stone_num=( udg_stone_num - 20 )
        set udg_tree_num=( udg_tree_num - 30 )
