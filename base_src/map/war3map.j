    endif
    // -------------------- µśŠńż║Õ»╣Ķ»ØµĪå --------------------
    call DialogDisplay(GetOwningPlayer(caster), LoadDialogHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x919E6CA2), true)
    // -------------------- µ│©ÕåīµīēķÆ«õ║ŗõ╗Č --------------------
