function Trig_Arrow_ShooterFunc022T takes nothing returns nothing
    local location targetPt= GetRectCenter(gg_rct_base_area)
    local location bossPt
    local location itemPt
    
    call IssuePointOrderLoc(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x944CCEB0), "attack", targetPt)
    call RemoveLocation(targetPt)
    
    if ( ( ( IsUnitDeadBJ(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x944CCEB0)) == true ) ) ) then
        set bossPt=GetUnitLoc(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x944CCEB0))
        call AddSpecialEffectLocBJ(bossPt, "Abilities\\Spells\\Orc\\EtherealForm\\SpiritWalkerChange.mdl")
        call YDWETimerDestroyEffect(2 , bj_lastCreatedEffect)
        
        set itemPt=PolarProjectionBJ(bossPt, 256, GetRandomDirectionDeg())
        call CreateItemLoc('I00D', itemPt)
        call RemoveLocation(itemPt)
        
        set itemPt=PolarProjectionBJ(bossPt, 256, GetRandomDirectionDeg())
        call CreateItemLoc('I00D', itemPt)
        call RemoveLocation(itemPt)
        
        if ( ( GetRandomInt(1, 100) <= 33 ) ) then
            call CreateItemLoc('I031', bossPt)
        endif
        
        set udg_bosswave=false
        set udg_base_wave_time=( udg_base_wave_time - udg_wave_interval_reduction )
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, 60.00, "|cffff0000µĢīÕ░åńÜäķÖ©ĶÉĮÕĮ╗Õ║Ģµ┐ĆµĆÆõ║åµĢīÕåø’╝īõ╗¢õ╗¼ńÜäµö╗ÕŖ┐ÕÅśÕŠŚĶČŖÕÅæÕćČńīø’╝üµÅÉķ½śĶŁ”µāĢ’╝īõ┐ØµīüµłÆÕżć’╝ü|r")
        call YDWETimerRunTrigger(2 , gg_trg_enemycoming)
        call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
        call DestroyTimer(GetExpiredTimer())
        call RemoveLocation(bossPt)
    endif
    
    if ( ( udg_difficulty > 1 ) ) then
        call ModifyHeroStat(bj_HEROSTAT_STR, LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x944CCEB0), bj_MODIFYMETHOD_ADD, 1)
        call ModifyHeroStat(bj_HEROSTAT_AGI, LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x944CCEB0), bj_MODIFYMETHOD_ADD, 1)
        call ModifyHeroStat(bj_HEROSTAT_INT, LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x944CCEB0), bj_MODIFYMETHOD_ADD, 1)
    endif
endfunction
