//===========================================================================
// Trigger: sin_lvup_new
//===========================================================================
//TESH.scrollpos=6
//TESH.alwaysfold=0
function Trig_sin_lvup_newConditions takes nothing returns boolean
    return GetUnitTypeId(GetTriggerUnit()) == 'H004' and GetItemTypeId(GetManipulatedItem()) == 'I00D'
endfunction
function Sin_FindItemSlotById takes unit u,integer itemId returns integer
    local integer i= 0
    local item it
    loop
        exitwhen i >= 6
        set it=UnitItemInSlot(u, i)
        if it != null and GetItemTypeId(it) == itemId then
            set it=null
            return i
        endif
        set i=i + 1
    endloop
    set it=null
    return - 1
endfunction
function Sin_CountItemById takes unit u,integer itemId returns integer
    local integer i= 0
    local integer count= 0
    local item it
    loop
        exitwhen i >= 6
        set it=UnitItemInSlot(u, i)
        if it != null and GetItemTypeId(it) == itemId then
            set count=count + 1
        endif
        set i=i + 1
    endloop
    set it=null
    return count
endfunction
function Sin_RemoveItemsById takes unit u,integer itemId,integer amount returns nothing
    local integer i= 0
    local integer removed= 0
    local item it
    loop
        exitwhen i >= 6 or removed >= amount
        set it=UnitItemInSlot(u, i)
        if it != null and GetItemTypeId(it) == itemId then
            call RemoveItem(it)
            set removed=removed + 1
        endif
        set i=i + 1
    endloop
    set it=null
endfunction
function Sin_TryUpgrade takes unit u,integer needLv,integer oldItemId,integer gemNeed,integer newItemId,boolean needLevel returns boolean
    local integer equipSlot
    local integer gemCount
    local item oldIt
    set equipSlot=Sin_FindItemSlotById(u , oldItemId)
    if equipSlot == - 1 then
        return false
    endif
    set gemCount=Sin_CountItemById(u , 'I00D')
    if gemCount < gemNeed then
        return false
    endif
    if needLevel and GetHeroLevel(u) < needLv then
        call DisplayTextToPlayer(GetOwningPlayer(u), 0, 0, "µé©ńÜäķøćõĮŻÕģĄÕĮōÕēŹńÜäĶāĮÕŖøõĖŹĶČ│õ╗źµÄźÕÅŚõĖŗõĖĆµ¼ĪńÜäÕÄ¤ńĮ¬Ķ»Ģńé╝")
        return true
    endif
    call Sin_RemoveItemsById(u , 'I00D' , gemNeed)
    set oldIt=UnitItemInSlot(u, equipSlot)
    if oldIt != null then
        call RemoveItem(oldIt)
    endif
    call UnitAddItemToSlotById(u, newItemId, equipSlot)
    call DisplayTextToPlayer(GetOwningPlayer(u), 0, 0, "µé©ńÜäķøćõĮŻÕģĄĶÄĘÕŠŚõ║åµø┤Õ╝║ńÜäńĮ¬ÕŁĮõ╣ŗÕŖø")
    set oldIt=null
    return true
endfunction
function Trig_sin_lvup_newActions takes nothing returns nothing
    local unit u= GetTriggerUnit()
    if Sin_TryUpgrade(u , 25 , 'I028' , 5 , 'I022' , true) then
        set u=null
        return
    endif
    if Sin_TryUpgrade(u , 20 , 'I027' , 5 , 'I028' , true) then
        set u=null
        return
    endif
    if Sin_TryUpgrade(u , 15 , 'I026' , 5 , 'I027' , true) then
        set u=null
        return
    endif
    if Sin_TryUpgrade(u , 10 , 'I025' , 4 , 'I026' , true) then
        set u=null
        return
    endif
    if Sin_TryUpgrade(u , 5 , 'I024' , 3 , 'I025' , true) then
        set u=null
        return
    endif
    call Sin_TryUpgrade(u , 0 , 'I023' , 3 , 'I024' , false)
    set u=null
endfunction
function InitTrig_sin_lvup_new takes nothing returns nothing
    set gg_trg_sin_lvup_new=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_sin_lvup_new, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_sin_lvup_new, Condition(function Trig_sin_lvup_newConditions))
    call TriggerAddAction(gg_trg_sin_lvup_new, function Trig_sin_lvup_newActions)
endfunction//===========================================================================
