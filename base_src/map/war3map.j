function Trig_Emerald_useConditions takes nothing returns boolean
    return ( ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true ) and ( GetItemTypeId(GetManipulatedItem()) == 'I03Z' ) and ( RectContainsUnit(gg_rct_swimmingpool, GetTriggerUnit()) == true ) )
