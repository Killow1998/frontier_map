function Trig_steal_soulConditions takes nothing returns boolean
    return ( ( ( GetUnitTypeId(GetKillingUnitBJ()) == 'H004' ) and ( IsUnitType(GetKillingUnitBJ(), UNIT_TYPE_HERO) == true ) and ( LoadBoolean(YDHT, 'H004', 0xFC90CAC3) == true ) and ( LoadBoolean(YDHT, 'H004', 0xD03034F6) == true ) and ( LoadBoolean(YDHT, 'H004', 0xB088C2E3) == true ) and ( GetRandomInt(1, 100) <= 13 ) ) )
endfunction
function Trig_steal_soulActions takes nothing returns nothing
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SaveInteger(YDHT, 'H004', 0x6CCF2C68, ( LoadInteger(YDHT, 'H004', 0x6CCF2C68) + 1 ))
    call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE2AED0F5, ( 80 + LoadInteger(YDHT, 'H004', 0x6CCF2C68) ))
    call SetHeroStr(GetKillingUnitBJ(), ( GetHeroStr(GetKillingUnitBJ(), false) + 1 ), true)
