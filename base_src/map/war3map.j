function Trig_enemy_groupConditions takes nothing returns boolean
    return ( ( ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true ) and ( GetSpellAbilityId() == 'A08T' ) ) )
endfunction
function Trig_enemy_groupActions takes nothing returns nothing
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SaveUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x944CCEB0, GetTriggerUnit())
    set udg_enemy_group_int=1
    loop
        exitwhen udg_enemy_group_int > 3
        call SaveLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xEAFE0942, PolarProjectionBJ(GetUnitLoc(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x944CCEB0)), GetRandomReal(80.00, 256.00), GetRandomDirectionDeg()))
        call AddSpecialEffectLocBJ(LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xEAFE0942), "Abilities\\Spells\\Orc\\FeralSpirit\\feralspirittarget.mdl")
        call YDWETimerDestroyEffect(0.34 , bj_lastCreatedEffect)
        call CreateNUnitsAtLoc(1, 'n011', GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x944CCEB0)), LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xEAFE0942), bj_UNIT_FACING)
        call SaveUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x39BCA3AA, bj_lastCreatedUnit)
        call SetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x39BCA3AA), UNIT_STATE_MAX_LIFE, ( GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x39BCA3AA), UNIT_STATE_MAX_LIFE) + ( 62.00 * I2R(udg_enemywaveCount) ) ))
        call SetUnitLifePercentBJ(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x39BCA3AA), 100)
        call YDWEGeneralBounsSystemUnitSetBonus(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x39BCA3AA) , 3 , 0 , GetRandomInt(1, 99))
        call UnitApplyTimedLife(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x39BCA3AA), 'BHwe', 42.00)
        set udg_enemy_group_int=udg_enemy_group_int + 1
    endloop
    set udg_enemy_group_int=1
    loop
        exitwhen udg_enemy_group_int > 2
        call SaveLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xEAFE0942, PolarProjectionBJ(GetUnitLoc(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x944CCEB0)), GetRandomReal(80.00, 256.00), GetRandomDirectionDeg()))
