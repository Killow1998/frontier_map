    if ( ( GetRandomInt(1, 100) <= 9 ) ) then
        call CreateItemLoc('I00D', LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xEAFE0942))
    else
        if ( ( GetUnitLevel(GetTriggerUnit()) >= 7 ) and ( GetRandomInt(1, 100) <= 15 ) ) then
            call CreateItemLoc('I00D', LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xEAFE0942))
        else
        endif
    endif
    // Õ░Åńü½ńÅĀ
