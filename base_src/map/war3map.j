function Trig_knife_use_newActions takes nothing returns nothing
    local trigger ydl_trigger
    local unit caster= GetTriggerUnit()
    local boolean is_used= false
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step) // µ£ĆõĖźµĀ╝ńÜäĶ¦äÕłÖ’╝ÜÕģ©µØæńÜä local ķāĮÕ£©Ķ┐ÖõĖŖķØó’╝īÕģ©µØæńÜäÕŖ©õĮ£ķāĮÕ£©Ķ┐ÖõĖŗķØó’╝ü

    // ==================== ÕÄ¤ńĮ¬ķśČń║¦µŗ”µł¬õĖÄĶ«░ÕĮĢķĆ╗ĶŠæ ====================
    // LV1 Õ░ÅÕłĆ (I023)
    if ( ( GetItemTypeId(YDWEGetItemOfTypeFromUnitBJNull(caster , 'I023')) == 'I023' ) ) then
        if ( ( LoadBoolean(YDHT, 'I023', 0x8376128B) == true ) ) then
            set is_used=true
        else
            call SaveBoolean(YDHT, 'I023', 0x8376128B, true)
