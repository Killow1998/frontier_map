function Trig_Emerald_useFunc005Func003T takes nothing returns nothing
    call AddSpecialEffectLocBJ(GetRectCenter(gg_rct_swimmingpool), "Abilities\\Spells\\Other\\Doom\\DoomDeath.mdl")
    call YDWETimerDestroyEffect(1.00 , bj_lastCreatedEffect)
    call CreateNUnitsAtLoc(1, 'U00K', Player(PLAYER_NEUTRAL_AGGRESSIVE), GetRectCenter(gg_rct_swimmingpool), bj_UNIT_FACING)
    call YDWEAddAIOrder(bj_lastCreatedUnit , 0 , 3 , null , null , "fanofknives" , 50)
endfunction
function Trig_Emerald_useFunc005T takes nothing returns nothing
