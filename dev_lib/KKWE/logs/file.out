function Trig_________________________uActions takes nothing returns nothing
    local integer ydul_i
    YDLocalInitialize()
    call YDLocal1Set(frame, "ui", DzCreateFrameByTagName("FRAME", "name", DzGetGameUI(), "template", 0))
    call YDLocal1Set(integer, "i", DzFrameGetAlpha(DzI2F(( DzF2I(YDLocal1Get(frame, "ui")) - 172 ))))
    call DzDestroyFrame( YDLocal1Get(frame, "ui") )
    call YDLocal1Set(integer, "i", ( YDLocal1Get(integer, "i") + 2537628 ))
    set ydul_i = 0
    loop
        exitwhen ydul_i > 63
        call DzSetMemory( YDLocal1Get(integer, "i"), 2.00 )
        call YDLocal1Set(integer, "i", ( YDLocal1Get(integer, "i") + 28 ))
        set ydul_i = ydul_i + 1
    endloop
    call YDLocal1Release()
endfunction

