function Trig_t01Func003CT takes nothing returns nothing
    if ((YDUserDataGet(player, GetLocalPlayer(), "重置镜头属性", boolean) == true)) then
        call SetCameraField( CAMERA_FIELD_ANGLE_OF_ATTACK, YDUserDataGet(player, GetLocalPlayer(), "镜头X角度", real), 0.00 )
        call SetCameraField( CAMERA_FIELD_TARGET_DISTANCE, YDUserDataGet(player, GetLocalPlayer(), "镜头距离", real), YDUserDataGet(player, GetLocalPlayer(), "镜头缩放平滑", real) )
        call YDUserDataSet(player, GetLocalPlayer(), "重置镜头属性", boolean, false)
    else
    endif
endfunction

function Trig_t01Func008WT takes nothing returns nothing
    if ((DzIsMouseOverUI() == false)) then
        return
    else
    endif
    call YDLocal6Set("Trig_t01Func008", integer, "delta", DzGetWheelDelta())
    call YDUserDataSet(player, GetLocalPlayer(), "重置镜头属性", boolean, true)
    if ((YDLocal6Get("Trig_t01Func008", integer, "delta") > 0)) then
        if ((YDLocal6Get("Trig_t01Func008", integer, "level") > 4)) then
            call YDLocal6Set("Trig_t01Func008", integer, "level", ( YDLocal6Get("Trig_t01Func008", integer, "level") - 1 ))
        else
        endif
    else
        if ((YDLocal6Get("Trig_t01Func008", integer, "level") < 20)) then
            call YDLocal6Set("Trig_t01Func008", integer, "level", ( YDLocal6Get("Trig_t01Func008", integer, "level") + 1 ))
        else
        endif
    endif
    call YDUserDataSet(player, GetLocalPlayer(), "镜头距离", real, ( I2R(YDLocal6Get("Trig_t01Func008", integer, "level")) * 200.00 ))
endfunction

function Trig_t01Actions takes nothing returns nothing
    YDLocalInitialize()
    // 鼠标滚轮控制视距
    if GetLocalPlayer() == GetLocalPlayer() then
    	call DzFrameSetUpdateCallbackByCode( function Trig_t01Func003CT)
    endif
    call YDLocal1Set(integer, "level", 8)
    call YDUserDataSet(player, GetLocalPlayer(), "镜头缩放平滑", real, 0.10)
    call YDUserDataSet(player, GetLocalPlayer(), "镜头X角度", real, 304.00)
    call YDUserDataSet(player, GetLocalPlayer(), "镜头距离", real, ( I2R(YDLocal1Get(integer, "level")) * 200.00 ))
    call SetCameraField( CAMERA_FIELD_TARGET_DISTANCE, YDUserDataGet(player, GetLocalPlayer(), "镜头距离", real), YDUserDataGet(player, GetLocalPlayer(), "镜头缩放平滑", real) )
    call YDLocal6Set("Trig_t01Func008", integer, "level", 8)
    call YDLocal6Set("Trig_t01Func008", integer, "delta", YDLocal1Get(integer, "delta"))
    if GetLocalPlayer() == GetLocalPlayer() then
    	call DzTriggerRegisterMouseWheelEventByCode( null, false, function Trig_t01Func008WT)
    endif
    call YDLocal1Release()
endfunction

