{
  "compilerOptions": {
    "target": "esnext",
    "lib": [
      "esnext"
    ],
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@eiriksgata/wc3ts": ["temp/index"],
      "@eiriksgata/wc3ts/*": ["temp/*"]
    },
    "types": [
      "@eiriksgata/wc3ts/types",
      "lua-types/5.3"
    ],
    "strict": true
  },
  "tstl": {
    "luaTarget": "5.3",
    "noHeader": true,
    "noImplicitSelf": true,
    "noResolvePaths": [
      "jass.common",
      "jass.ai",
      "jass.globals",
      "jass.japi",
      "jass.hook",
      "jass.runtime",
      "jass.slk",
      "jass.console",
      "jass.debug",
      "jass.log",
      "jass.runtime",
      "jass.message",
      "jass.bignum"
    ],
    "luaBundle": "maps/map/main.lua",
    "luaBundleEntry": "temp/main.ts"
  },
  "include": [
    "src",
    "temp/**/*"
  ]
}