{
  "compilerOptions": {
    "target": "esnext",
    "lib": [
      "esnext"
    ],
    "moduleResolution": "node",
    "types": [
      "wc3ts-1.27a/types",
      "lua-types/5.3",
      "lua-types/core/coroutine",
      "lua-types/core/global",
      "lua-types/core/math",
      "lua-types/core/metatable",
      "lua-types/core/modules",
      "lua-types/core/string",
      "lua-types/core/table",
      "lua-types/core/os",
      "@typescript-to-lua/language-extensions",
    ],
    "strict": true,
    "allowJs": false,
  },
  "tstl": {
    "luaTarget": "5.3",
    "noImplicitSelf": true,
    "noHeader": true,
    "luaLibImport": "require",
    "sourceMapTraceback": false,
    "noResolvePaths": [
      "jass.common",
      "jass.ai",
      "jass.globals",
      "jass.japi",
      "jass.hook",
      "jass.runtime",
      "jass.slk",
      "jass.console",
      "jass.debug",
      "jass.log",
      "jass.runtime",
      "jass.message",
      "jass.bignum",
      "typescript",
      "typescript-to-lua"
    ],
    "luaBundle": "maps/map/main.lua",
    "luaBundleEntry": "src/index.ts"
  },
  "include": [
    "src/**/*",
    "types/**/*"
  ]
}